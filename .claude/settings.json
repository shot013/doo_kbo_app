{
  "permissions": {
    "allow": [
      "Bash(flutter --version)",
      "Bash(flutter pub *)",
      "Bash(git init *)",
      "Bash(dart format *)",
      "Bash(flutter analyze *)",
      "Bash(flutter test *)",
      "Bash(flutter run *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/block-generated-edit.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/format-dart.sh\""
          }
        ]
      }
    ]
  }
}